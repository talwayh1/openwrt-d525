config system
	option hostname 'OpenWrt-D525'
	option timezone 'CST-8'
	option zonename 'Asia/Shanghai'
	option ttylogin '0'
	option log_size '256'
	option urandom_seed '0'

config timeserver 'ntp'
	list server 'ntp.aliyun.com'
	list server 'ntp.tencent.com'
	list server 'time1.cloud.tencent.com'
	option enable_server '1'

# D525 4-port router: enable SFP LED indicators if available
# The D525 boards typically have GPIO-controlled LEDs for each NIC
